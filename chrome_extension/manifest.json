{
  "manifest_version": 3,
  "name": "Export Sales Navigator data as CSV",
  "version": "1.0.5",
  "key": "",
  "description": "Export Sales Navigator data as CSV",
  "background": {
    "service_worker": "src/bg/background.js"
  },
  "permissions": [
    "activeTab",
    "cookies",
    "storage",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://alpha-foundry.alphanext.tech/*"
  ],
  "update_url": "https://leadextractor-host-production.up.railway.app/update.xml",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "css": [
        "src/inject/inject.css"
      ]
    },
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "src/inject/linkedin-jobs-history-hook-main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "src/jquery.js", "src/inject/inject.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/inject/*.svg",
        "src/inject/*.png",
        "src/inject/interceptRequest.js"
      ],
      "matches": [
        "https://www.linkedin.com/*"
      ]
    }
  ]
}